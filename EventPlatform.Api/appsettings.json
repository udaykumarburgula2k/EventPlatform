{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=EventPlatformDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "EventPlatform",
    "Audience": "EventPlatform.Client",
    "Key": "THIS_IS_A_DEMO_KEY_CHANGE_ME_TO_A_LONG_RANDOM_SECRET_12345",
    "ExpiryMinutes": 120
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Modules": {
    "Auth": {
      "AllowOrganizerSelfRegistration": true,
      "AllowAttendeeSelfRegistration": true,
      "RequireEmailVerification": false
    },
    "Events": {
      "Enabled": true,
      "AllowDelete": false,
      "RequireApprovalBeforePublish": true,
      "MaxSpeakersPerEvent": 10
    },
    "Registration": {
      "Enabled": true,
      "PaymentRequired": true,
      "MaxTicketsPerUserPerEvent": 5,
      "CancellationWindowHours": 24
    }
  }
}